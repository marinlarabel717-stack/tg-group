{
  "name": "telegram-multi-account-manager",
  "version": "0.0.1",
  "private": true,
  "description": "TG Group desktop manager",
  "author": "TG Group",
  "license": "UNLICENSED",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "pack:dir": "npm run build && electron-builder --dir --publish never",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "dist:portable": "npm run build && electron-builder --win portable --publish never"
  },
  "build": {
    "appId": "ai.tggroup.desktop",
    "productName": "TG Group",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/accounts/telegram-web-preload.cjs",
        "to": "runtime/accounts/telegram-web-preload.cjs"
      },
      {
        "from": "electron/accounts/check-engine/telethon_freeze_check.py",
        "to": "runtime/accounts/check-engine/telethon_freeze_check.py"
      }
    ],
    "asar": true,
    "npmRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": false
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://example.com/tg-group/releases"
      }
    ]
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.17",
    "framer-motion": "^11.11.17",
    "libphonenumber-js": "^1.13.0",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "telegram": "^2.26.22",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.15.17",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "electron": "^35.2.0",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
