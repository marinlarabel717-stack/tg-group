{
  "name": "telegram-multi-account-manager",
  "version": "0.0.77",
  "private": true,
  "description": "TG-Matrix desktop manager",
  "author": "TG-Matrix",
  "license": "UNLICENSED",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "patch:telegram-repeat": "node scripts/patch-telegram-repeat.cjs",
    "build": "npm run patch:telegram-repeat && tsc && vite build",
    "prepare:python-runtime": "node scripts/prepare-python-runtime.cjs",
    "postinstall": "node scripts/patch-telegram-repeat.cjs",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "pack:dir": "npm run prepare:python-runtime && npm run build && electron-builder --dir --publish never",
    "dist:win": "npm run prepare:python-runtime && npm run build && electron-builder --win nsis --publish never",
    "dist:exe": "npm run prepare:python-runtime && npm run build && electron-builder --win nsis --x64 --publish never",
    "dist:portable": "npm run prepare:python-runtime && npm run build && electron-builder --win portable --publish never",
    "license:server": "node license-server/server.mjs",
    "license:create-card": "node license-server/create-card.mjs",
    "license:list-cards": "node license-server/list-cards.mjs",
    "license:get-card": "node license-server/get-card.mjs",
    "license:disable-card": "node license-server/disable-card.mjs",
    "license:extend-card": "node license-server/extend-card.mjs",
    "license:reset-devices": "node license-server/reset-devices.mjs",
    "license:list-logs": "node license-server/list-logs.mjs"
  },
  "build": {
    "appId": "ai.tgmatrix.desktop",
    "productName": "TG-Matrix",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/accounts/telegram-web-preload.cjs",
        "to": "runtime/accounts/telegram-web-preload.cjs"
      },
      {
        "from": "electron/accounts/check-engine/telethon_freeze_check.py",
        "to": "runtime/accounts/check-engine/telethon_freeze_check.py"
      },
      {
        "from": "electron/accounts/check-engine/telethon_spambot_check.py",
        "to": "runtime/accounts/check-engine/telethon_spambot_check.py"
      },
      {
        "from": "electron/accounts/check-engine/telethon_account_survival.py",
        "to": "runtime/accounts/check-engine/telethon_account_survival.py"
      },
      {
        "from": "electron/accounts/telethon_twofa_manage.py",
        "to": "runtime/accounts/telethon_twofa_manage.py"
      },
      {
        "from": "electron/accounts/telethon_profile_manage.py",
        "to": "runtime/accounts/telethon_profile_manage.py"
      },
      {
        "from": "electron/accounts/telethon_read_premium.py",
        "to": "runtime/accounts/telethon_read_premium.py"
      },
      {
        "from": "electron/accounts/telethon_read_web_state.py",
        "to": "runtime/accounts/telethon_read_web_state.py"
      },
      {
        "from": "electron/direct-message/telethon_group_collect.py",
        "to": "runtime/direct-message/telethon_group_collect.py"
      },
      {
        "from": "electron/direct-message/telethon_direct_message_send.py",
        "to": "runtime/direct-message/telethon_direct_message_send.py"
      },
      {
        "from": "electron/auto-join/telethon_auto_join.py",
        "to": "runtime/auto-join/telethon_auto_join.py"
      },
      {
        "from": "electron/broadcast/telethon_list_joined_groups.py",
        "to": "runtime/broadcast/telethon_list_joined_groups.py"
      },
      {
        "from": "electron/broadcast/telethon_scheduled_messages.py",
        "to": "runtime/broadcast/telethon_scheduled_messages.py"
      },
      {
        "from": "build/runtime/python",
        "to": "runtime/python"
      },
      {
        "from": "build/icon.png",
        "to": "runtime/app/icon.png"
      }
    ],
    "asar": true,
    "npmRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "executableName": "TG-Matrix",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "http://tgmatrix.duckdns.org/releases"
      }
    ]
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.17",
    "electron-updater": "^6.8.3",
    "framer-motion": "^11.11.17",
    "libphonenumber-js": "^1.13.0",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "telegram": "^2.26.22",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.15.17",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "electron": "^35.2.0",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
